# Parallel Stages in Jenkins

Parallel stages allow multiple stages to run simultaneously instead of one after anoth

pipeline {
agent any

    stages {

        stage('Testing') {

            parallel {

                stage('Linux Test') {
                    steps {
                        echo 'Running Linux Tests'
                    }
                }

                stage('Windows Test') {
                    steps {
                        echo 'Running Windows Tests'
                    }
                }

                stage('Mac Test') {
                    steps {
                        echo 'Running Mac Tests'
                    }
                }
            }
        }
    }

}


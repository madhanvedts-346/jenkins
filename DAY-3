# Environment Variables in Jenkins

Environment variables are used to store values such as paths, URLs, build numbers, and configuration settings that can be accessed throughout the pipeline.

# 1.Pipeline-Level Environment Variables

pipeline {
agent any

    environment {
        APP_NAME = "my-app"
        ENV = "dev"
    }

    stages {
        stage('Build') {
            steps {
                echo "Application: ${APP_NAME}"
                echo "Environment: ${ENV}"
            }
        }
    }

}

# 2. Stage-Level Environment Variables

pipeline {
agent any

    stages {
        stage('Build') {
            environment {
                JAVA_HOME = "/opt/java"
            }

            steps {
                echo "${JAVA_HOME}"
            }
        }
    }

}

# 3. Access Existing Jenkins Environment Variables

pipeline {
agent any

    stages {
        stage('Info') {
            steps {
                echo "Build Number: ${env.BUILD_NUMBER}"
                echo "Job Name: ${env.JOB_NAME}"
                echo "Workspace: ${env.WORKSPACE}"
            }
        }
    }

}

# 4. Using withEnv

pipeline {
agent any

    stages {
        stage('Build') {
            steps {
                withEnv(["ENV=prod", "VERSION=2.0"]) {
                    sh 'echo $ENV'
                    sh 'echo $VERSION'
                }
            }
        }
    }

}

#After the block ends, variables are removed.

## Real DevOps Example

pipeline {
agent any

    environment {
        APP_NAME = "springboot-app"
        DOCKER_IMAGE = "madhan/springboot-app"
        AWS_REGION = "ap-south-1"
    }

    stages {

        stage('Build') {
            steps {
                sh 'mvn clean package'
            }
        }

        stage('Docker Build') {
            steps {
                sh 'docker build -t $DOCKER_IMAGE:$BUILD_NUMBER .'
            }
        }

        stage('Deploy') {
            steps {
                echo "Deploying ${APP_NAME}"
                echo "Build Number ${BUILD_NUMBER}"
            }
        }
    }

}


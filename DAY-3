# Difference between Declarative and Scripted Pipeline in Jenkins

Declarative Pipeline uses a predefined, structured syntax and is easier to read, maintain, and validate. It is the recommended approach for most CI/CD pipelines. Scripted Pipeline is written using Groovy code and provides greater flexibility, allowing complex logic such as loops, conditions, and custom functions. Declarative is preferred for standard workflows, while Scripted is used when advanced pipeline customization is required.

# Error handling

# 1.Using post Block

pipeline {
agent any

    stages {
        stage('Build') {
            steps {
                sh 'exit 1'
            }
        }
    }

    post {
        success {
            echo 'Build Successful'
        }

        failure {
            echo 'Build Failed'
        }

        always {
            echo 'Cleanup Activities'
        }
    }

}

# 2.Using Try-Catch

pipeline {
agent any

    stages {
        stage('Build') {
            steps {
                script {
                    try {
                        sh 'exit 1'
                    }
                    catch(Exception e) {
                        echo "Exception: ${e}"
                    }
                }
            }
        }
    }

}

# 3. Using catchError

pipeline {
agent any

    stages {
        stage('Build') {
            steps {
                catchError(buildResult: 'SUCCESS',
                           stageResult: 'FAILURE') {

                    sh 'exit 1'
                }
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deploying'
            }
        }
    }

}

# 4.Mark Build as Unstable

pipeline {
agent any

    stages {
        stage('Test') {
            steps {
                script {
                    unstable("Some test cases failed")
                }
            }
        }
    }

}

# 5.Fail Build Explicitly

pipeline {
agent any

    stages {
        stage('Validation') {
            steps {
                script {
                    error("Mandatory file missing")
                }
            }
        }
    }

}

# 6.Retry Failed Step

pipeline {
agent any

    stages {
        stage('Download') {
            steps {
                retry(3) {
                    sh 'curl http://server/file'
                }
            }
        }
    }

}

# 7.Timeout Handling

pipeline {
agent any

    stages {
        stage('Long Running Task') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    sh './longjob.sh'
                }
            }
        }
    }

}

# 8.Continue Pipeline After Failure

pipeline {
agent any

    stages {
        stage('Build') {
            steps {
                script {
                    try {
                        sh 'exit 1'
                    }
                    catch(Exception e) {
                        echo "Build failed"
                    }
                }
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deployment continues'
            }
        }
    }

}

# 9. Set Build Result Manually

pipeline {
agent any

    stages {
        stage('Test') {
            steps {
                script {
                    currentBuild.result = 'UNSTABLE'
                }
            }
        }
    }

}

###

currentBuild.result = 'SUCCESS'
currentBuild.result = 'UNSTABLE'
currentBuild.result = 'FAILURE'
currentBuild.result = 'ABORTED'

